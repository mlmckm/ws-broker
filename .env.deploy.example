# ── Coolify Bağlantı ─────────────────────────────────────────────────────────
COOLIFY_URL=https://coolify.sirketim.com
COOLIFY_TOKEN=buraya-coolify-api-token

# ── GitHub Repo ───────────────────────────────────────────────────────────────
GITHUB_REPO=https://github.com/KULLANICI_ADI/ws-broker
GITHUB_BRANCH=main

# ── Server & Project (boş bırakılırsa otomatik algılanır) ─────────────────────
# COOLIFY_SERVER=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# COOLIFY_PROJECT=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Uygulama Secrets (MUTLAKA DEĞİŞTİRİN) ────────────────────────────────────
JWT_SECRET=en-az-64-karakter-cok-gizli-rastgele-bir-string-buraya-yazin-XXXX
API_KEY=guclu-api-anahtari-buraya
ADMIN_PASSWORD=guclu-admin-sifreniz

# ── Deploy sonrası otomatik eklenir (değiştirmeyin) ───────────────────────────
# COOLIFY_APP_UUID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# COOLIFY_DB_UUID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
