# ── Coolify Bağlantı ─────────────────────────────────────────────────────────
COOLIFY_URL=https://paas.ensimlive.com
COOLIFY_TOKEN=buraya-coolify-api-token

# ── Deploy Hedefi ─────────────────────────────────────────────────────────────
COOLIFY_APP_UUID=buraya-uygulama-uuid
COOLIFY_DB_UUID=buraya-db-uuid

# ── GitHub Repo ───────────────────────────────────────────────────────────────
GITHUB_REPO=https://github.com/mlmckm/ws-broker
GITHUB_BRANCH=main

# ── Uygulama Secrets ─────────────────────────────────────────────────────────
JWT_SECRET=buraya-min-64-karakter-secret
API_KEY=buraya-api-key
ADMIN_PASSWORD=buraya-admin-sifresi
